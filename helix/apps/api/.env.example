DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helix_dev
NODE_ENV=development
APPLICATIONINSIGHTS_CONNECTION_STRING=
JWT_SECRET=helix-dev-secret-change-in-production
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=

# EPAM DIAL AI Integration
# GATE: Art. 28 DPA must be signed (NFR10) and AI governance approved (Q-005) before enabling in production
# EU-hosted DIAL endpoint required (NFR6 — no cross-border AI calls)
# Leave blank to run in stub mode (safe for local dev and CI without real DPA)
DIAL_API_URL=
DIAL_API_KEY=
DIAL_MODEL_DEPLOYMENT=gpt-4o
DIAL_TIMEOUT_MS=3000

# Email Notifications (Story 4.5)
# Set EMAIL_TRANSPORT to 'smtp' or 'acs'. Leave empty to disable email notifications.
EMAIL_TRANSPORT=
FRONTEND_BASE_URL=https://helix.stada.de

# SMTP transport (EMAIL_TRANSPORT=smtp)
SMTP_HOST=mail.stada.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=helix@stada.de
SMTP_PASS=
SMTP_FROM=helix@stada.de

# Azure Communication Services transport (EMAIL_TRANSPORT=acs)
ACS_CONNECTION_STRING=
ACS_SENDER_ADDRESS=helix@stada.de

# File storage — all three required for Azure Blob; omit all to use local disk (default for local dev)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=
AZURE_STORAGE_SAS_TOKEN=
